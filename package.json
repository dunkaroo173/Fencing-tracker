{
  "name": "sclass-fencing-tournament",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest --watchAll=false"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.1.2",
    "expo": "~52.0.47",
    "expo-file-system": "~18.0.12",
    "expo-sharing": "~12.0.1",
    "expo-speech": "~13.0.0",
    "expo-status-bar": "~2.0.1",
    "react": "18.2.0",
    "react-native": "0.76.9"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/react": "~18.3.12",
    "@types/jest": "^29.5.14",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "~5.3.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "moduleFileExtensions": ["ts", "tsx", "js", "jsx"],
    "testMatch": ["**/__tests__/**/*.test.ts"],
    "transform": {
      "^.+\\.(ts|tsx)$": ["ts-jest", { "tsconfig": { "jsx": "react" } }]
    },
    "moduleNameMapper": {
      "expo-speech": "<rootDir>/__mocks__/expo-speech.js"
    }
  }
}
